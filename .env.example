# Copy to `.env` and fill in. The `.env` file is gitignored.
# Set up Gmail App Password: https://myaccount.google.com/apppasswords
# (Requires 2-step verification on the Google account first.)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
NOTIFY_FROM=your-address@gmail.com
NOTIFY_TO=your-address@gmail.com

# Other SMTP providers also work — e.g. Outlook (smtp-mail.outlook.com:587)
# or Fastmail (smtp.fastmail.com:465 with SMTP_PORT=465 for TLS).
